# 实例名称（字母数字和连字符，同一台服务器上唯一）
INSTANCE_NAME=default
# 对外暴露端口，同一台服务器上多个实例需使用不同端口
INSTANCE_PORT=18789
# 实例业务定位（用于生成 BOOTSTRAP.md，让 agent 知道自己服务哪块业务）
INSTANCE_ROLE=通用个人助手

# GPT / OpenAI API 配置
GPT_API_URL=https://code-cli.fanfansay.top/v1
GPT_API_KEY=你的 API Key

# 生成图片专用 API（openai-image-gen skill 使用，对应 OPENAI_BASE_URL / OPENAI_API_KEY）
IMAGE_API_URL=https://code-cli.fanfansay.top/v1
IMAGE_API_KEY=你的图片生成 API Key

# 飞书机器人配置
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Chrome CDP 地址（使用 services/chrome/ 目录单独启动 Chrome 后填写）
# 格式：http://<宿主机IP>:9223
CHROME_CDP_URL=http://127.0.0.1:9223

# 访问控制（allowedOrigins）
OPENCLAW_HTTPS_ORIGIN=https://openclaw.smarteamlab.com
OPENCLAW_HTTP_ORIGIN=http://45.32.199.207:18789
