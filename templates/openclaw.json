{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "models": {
        "openai/gpt-5.5": {
          "alias": "GPT"
        },
        "openai/gpt-5.4": {},
        "custom-gpt/gpt-5.5": {}
      },
      "model": {
        "primary": "custom-gpt/gpt-5.5"
      },
      "sandbox": {
        "mode": "off"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [
        "${OPENCLAW_HTTPS_ORIGIN}",
        "${OPENCLAW_HTTP_ORIGIN}"
      ],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "请替换为随机字符串或运行 gen_token.sh"
    },
    "port": 18789,
    "bind": "lan",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    },
    "trustedProxies": [
      "172.16.0.0/12",
      "127.0.0.1/8"
    ],
    "remote": {
      "token": "请替换为随机字符串或运行 gen_token.sh",
      "url": "ws://127.0.0.1:18789"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.6.1",
    "lastTouchedAt": "2026-06-03T19:11:16.000Z"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding",
    "alsoAllow": [
      "browser"
    ],
    "web": {
      "search": {
        "provider": "duckduckgo",
        "enabled": true
      }
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      },
      "duckduckgo": {
        "enabled": true
      },
      "device-pair": {
        "enabled": true
      },
      "feishu": {
        "enabled": true
      },
      "codex": {
        "enabled": true
      },
      "browser": {
        "enabled": true
      }
    },
    "allow": [
      "feishu",
      "browser",
      "codex"
    ]
  },
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-06-03T19:11:16.000Z",
    "lastRunVersion": "2026.6.1",
    "lastRunCommand": "configure",
    "lastRunMode": "local"
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "domain": "feishu",
      "connectionMode": "websocket",
      "dmPolicy": "pairing",
      "allowFrom": [],
      "groupPolicy": "allowlist",
      "groupAllowFrom": [],
      "requireMention": true,
      "accounts": {
        "default": {
          "appId": "${FEISHU_APP_ID}",
          "appSecret": "${FEISHU_APP_SECRET}"
        }
      },
      "streaming": false,
      "blockStreaming": false
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "custom-gpt": {
        "baseUrl": "${GPT_API_URL}",
        "api": "openai-completions",
        "apiKey": "${GPT_API_KEY}",
        "models": [
          {
            "id": "gpt-5.5",
            "name": "gpt-5.5 (Custom Provider)",
            "contextWindow": 400000,
            "maxTokens": 4096,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "reasoning": false
          }
        ],
        "contextWindow": 400000
      }
    }
  },
  "commands": {
    "ownerAllowFrom": []
  },
  "browser": {
    "enabled": true,
    "cdpUrl": "${CHROME_CDP_URL}"
  }
}
